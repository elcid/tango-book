# Telekom hosting credentials for scripts/deploy-telekom.sh
# Copy this to .env.telekom and fill in your values.
#
# The .env.telekom file is gitignored — never commit credentials.

# Your Telekom SFTP/SSH hostname. Common values:
#   home.telekom.de            (Telekom webhosting)
#   ssh.wpxxxx.securehostdns.com  (example, check your Telekom contract email)
TELEKOM_HOST=

# Your Telekom username (often an email or numeric ID)
TELEKOM_USER=

# Remote document root where your website files live.
# Common Telekom paths:
#   /www/htdocs/<username>     (Webhosting Advanced)
#   /home/<username>/html      (some configurations)
#   ~/html                     (short form)
TELEKOM_PATH=
