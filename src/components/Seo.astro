---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
  locale?: string;
  robots?: string;
}

const baseUrl = new URL(import.meta.env.BASE_URL, Astro.site).href;
const defaultImage = import.meta.env.BASE_URL.replace(/\/?$/, '/') + "TangoBuch.png";

const {
  title = "Tango in allen Lebenslagen",
  description = "Anekdoten über Musiker, Sänger und Tänzer — ein faszinierendes Sammelwerk über die Welt des Tangos von Dr. J. Rodrigo Reyes Martínez und Monika Fröhlich.",
  image = defaultImage,
  url = baseUrl,
  type = "website",
  locale = "de_DE",
  robots = "index, follow",
} = Astro.props;
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image.startsWith("http") ? image : new URL(image, Astro.site).href} />
<meta property="og:url" content={url} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content="Tango in allen Lebenslagen" />
<meta property="og:locale" content={locale} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image.startsWith("http") ? image : new URL(image, Astro.site).href} />

<link rel="canonical" href={url} />

<!-- Structured data slot for JSON-LD -->
{ Astro.slots.has("structured-data") && <slot name="structured-data" /> }
